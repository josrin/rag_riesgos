# Configuracion del pipeline RAG
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=llama3
EMBEDDING_MODEL=bge-m3

# Rutas
DOCS_DIR=docs
CHROMA_DIR=data/chroma
QUERIES_DB=data/queries.db

# Chunking
CHUNK_SIZE=900
CHUNK_OVERLAP=150

# Retrieval
# 7 fragmentos al LLM: 2 de margen sobre el "ideal" de 5 para tolerar
# ranking menos preciso en preguntas compuestas o en consultas donde el
# chunk correcto queda en el limite del top-5.
TOP_K=7

# Reranker cross-encoder (BAAI/bge-reranker-v2-m3). Descarga ~2 GB la
# primera vez desde HuggingFace Hub. Deshabilitado por defecto: en un
# corpus pequeño (<= 50 chunks) el hibrido BM25+vector ya es suficiente
# y el reranker añade ~9 s de latencia en CPU. Habilitarlo cuando el
# corpus crezca a cientos/miles de chunks.
RERANKER_ENABLED=false
RERANKER_POOL_SIZE=20
# 0.0 = ignorar reranker (solo RRF); 1.0 = puro cross-encoder; 0.5 = mezcla balanceada
RERANKER_ALPHA=0.5

LOG_RETENTION_DAYS=30

# OCR (opcional) — se activa solo cuando un PDF trae paginas escaneadas
# (<40 chars nativos). Si todos tus documentos son .txt / .md / PDF digital,
# puedes dejar estas variables como estan o incluso comentarlas.
#
# Instalacion via winget (Windows):
#   winget install --id UB-Mannheim.TesseractOCR
#   winget install --id oschwartz10612.Poppler
#
# Idioma espanol:
#   Opcion A (recomendada): durante el instalador de Tesseract marca
#   "Spanish" en "Additional language data". Queda en Program Files
#   y NO necesitas TESSDATA_PREFIX — comenta esa linea.
#
#   Opcion B (si no puedes tocar Program Files): descarga
#   https://github.com/tesseract-ocr/tessdata/raw/main/spa.traineddata
#   y colocalo junto a eng.traineddata / osd.traineddata en la ruta
#   apuntada por TESSDATA_PREFIX.
#
# <USUARIO> = reemplaza por tu usuario de Windows. La version de Poppler
# puede variar segun la fecha; ajusta segun lo que te haya instalado winget.

TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
POPPLER_PATH=C:\Users\<USUARIO>\AppData\Local\Microsoft\WinGet\Packages\oschwartz10612.Poppler_Microsoft.Winget.Source_8wekyb3d8bbwe\poppler-25.07.0\Library\bin
# TESSDATA_PREFIX=C:\Data Projects\rag-riesgos\data\tessdata  # solo opcion B
